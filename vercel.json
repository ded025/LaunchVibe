{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/proofbase run build",
  "outputDirectory": "artifacts/proofbase/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/((?!assets|.*\\..*).*)", "destination": "/index.html" }
  ],
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "build": {
    "env": {
      "PORT": "3000",
      "BASE_PATH": "/",
      "NODE_ENV": "production"
    }
  }
}
